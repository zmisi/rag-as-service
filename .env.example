# Database (SQLAlchemy / Alembic)
# Local Homebrew: use your OS username (replace USER). Docker often uses postgres/postgres.
DATABASE_URL=postgresql+psycopg://dbagent@127.0.0.1:5432/lxzxai_rag

# Run `alembic upgrade head` on API process startup (default true)
AUTO_MIGRATE=true

# 会话与安全
SECRET_KEY=change_me_use_openssl_rand_hex_32
SESSION_COOKIE_NAME=pb_session
SESSION_COOKIE_DOMAIN=.lxzxai.com
SESSION_TTL_DAYS=14

# 主站 Host（注册/登录仅允许此 apex）
APEX_HOST=lxzxai.com

# 本地开发 URL
API_HOST=0.0.0.0
API_PORT=8000
WEB_PORT=3000

# Next.js BFF → FastAPI（app/backend/[...path] 薄反代）
API_BACKEND_URL=http://localhost:8000
# Shared secret so API trusts X-Forwarded-Host only from Next/Caddy (not browser).
PROXY_SHARED_SECRET=local-dev-proxy-secret

# Cookie Secure：生产 true；本地 HTTP 可设 false
COOKIE_SECURE=false

# Dev-only auth stub for F05 UI (accepts X-Test-User-Id). Keep false in prod.
AUTH_STUB_ENABLED=false

# QWen (DashScope OpenAI-compatible). Required in prod.
# Local dev: with AUTH_STUB_ENABLED=true and empty QWEN_API_KEY, API uses DevStubLlmClient.
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# F04/F08 indexing / embeddings
# Office OOXML (.docx/.xlsx/.pptx) uses lightweight libs (python-docx/openpyxl/python-pptx), not Docling.
# PDF structure path may still need: uv sync --extra docling
QWEN_EMBEDDING_ENABLED=false
QWEN_EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=1024
CHUNK_TARGET_TOKENS=800
CHUNK_OVERLAP_TOKENS=100
# Inline index after publish (local e2e without worker). Prefer false + rag-index-worker.
INDEX_SYNC_ON_PUBLISH=false
INDEX_WORKER_POLL_INTERVAL_SECONDS=2
INDEX_WORKER_BATCH_SIZE=5
INDEX_JOB_STUCK_AFTER_SECONDS=1800
# PDF PyMuPDF fast-path quality gate (conservative; raise to force more Docling).
PDF_FAST_MIN_CHARS=80
PDF_FAST_MIN_CHARS_PER_PAGE=40
PDF_FAST_MIN_PRINTABLE_RATIO=0.85
PDF_FAST_MAX_EMPTY_PAGE_RATIO=0.50
# PDF skeleton → Docling structure path (TOC / font heading candidates)
PDF_SKELETON_MIN_TOC=1
PDF_SKELETON_MIN_HEADING_CANDIDATES=3
PDF_FORCE_STRUCTURE=false

# Upload type gate: extension allowlist + magic bytes (F08). No extra env knobs.

# Phase 1 local object storage root (document uploads)
# STORAGE_ROOT=
