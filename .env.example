# Database (SQLAlchemy / Alembic)
# Local Homebrew: use your OS username (replace USER). Docker often uses postgres/postgres.
DATABASE_URL=postgresql+psycopg://dbagent@127.0.0.1:5432/lxzxai_rag

# Run `alembic upgrade head` on API process startup (default true)
AUTO_MIGRATE=true

# 会话与安全
SECRET_KEY=change_me_use_openssl_rand_hex_32
SESSION_COOKIE_NAME=pb_session
SESSION_COOKIE_DOMAIN=.lxzxai.com
SESSION_TTL_DAYS=14

# 主站 Host（注册/登录仅允许此 apex）
APEX_HOST=lxzxai.com

# 本地开发 URL
API_HOST=0.0.0.0
API_PORT=8000
WEB_PORT=3000

# Next.js → FastAPI 反代目标（apps/web rewrites /backend/*）
API_BACKEND_URL=http://localhost:8000

# Cookie Secure：生产 true；本地 HTTP 可设 false
COOKIE_SECURE=false

# Dev-only auth stub for F05 UI (accepts X-Test-User-Id). Keep false in prod.
AUTH_STUB_ENABLED=false

# QWen (DashScope OpenAI-compatible). Required in prod.
# Local dev: with AUTH_STUB_ENABLED=true and empty QWEN_API_KEY, API uses DevStubLlmClient.
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
