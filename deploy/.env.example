# Docker Compose — copy to repo root as .env
#   cp deploy/.env.example .env

POSTGRES_USER=rag_app
POSTGRES_PASSWORD=rag_app
POSTGRES_DB=lxzxai_rag
POSTGRES_PORT=5432

API_PORT=8000
WEB_PORT=3000
CADDY_PORT=8080

AUTO_MIGRATE=true
COOKIE_SECURE=false

SECRET_KEY=change_me_use_openssl_rand_hex_32
SESSION_COOKIE_NAME=pb_session
SESSION_COOKIE_DOMAIN=.lxzxai.com
SESSION_TTL_DAYS=14
APEX_HOST=lxzxai.com

# Shared secret: Next BFF / Caddy → API (never set from browser)
PROXY_SHARED_SECRET=local-dev-proxy-secret

# API → Postgres（compose 内 api 服务会自动注入；本地 pytest / 原生进程可设）
DATABASE_URL=postgresql+psycopg://rag_app:rag_app@127.0.0.1:5432/lxzxai_rag

# F04 indexing
EMBEDDING_DIM=1024
CHUNK_TARGET_TOKENS=800
CHUNK_OVERLAP_TOKENS=100
QWEN_EMBEDDING_ENABLED=false
QWEN_EMBEDDING_MODEL=text-embedding-v4
# Prefer dedicated index-worker service (compose default false)
INDEX_SYNC_ON_PUBLISH=false
INDEX_WORKER_POLL_INTERVAL_SECONDS=2
INDEX_WORKER_BATCH_SIZE=5
INDEX_JOB_STUCK_AFTER_SECONDS=1800
# PDF PyMuPDF → Docling quality gate
PDF_FAST_MIN_CHARS=80
PDF_FAST_MIN_CHARS_PER_PAGE=40
PDF_FAST_MIN_PRINTABLE_RATIO=0.85
INSTALL_DOCLING=0
# Docker pip mirror (default Tsinghua). Empty PIP_INDEX_URL = official PyPI.
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn
PDF_FAST_MAX_EMPTY_PAGE_RATIO=0.50
# PDF skeleton → Docling (set PDF_FORCE_STRUCTURE=true to always use structure path)
PDF_SKELETON_MIN_TOC=1
PDF_SKELETON_MIN_HEADING_CANDIDATES=3
PDF_FORCE_STRUCTURE=false

# QWen / DashScope（聊天 Agent 必填；未注入到 api 容器会报 QWen is not configured）
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
